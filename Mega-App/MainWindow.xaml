<Window x:Class="MegaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MegaApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Frame Source="Pages/HomePage.xaml" NavigationUIVisibility="Hidden"></Frame>

        <Border Background="#1A1A1A" Height="60" VerticalAlignment="Top" Panel.ZIndex="1">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content=" About us " Style="{StaticResource NavLinkTextStyle}" Click="OpenNotImpWin"/>
                    <Button Content=" דרושים " Style="{StaticResource NavLinkTextStyle}" Click="OpenNotImpWin"/>
                    <Button Content=" תמיכה טכנית ושירות " Style="{StaticResource NavLinkTextStyle}" Click="OpenNotImpWin"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="התחברות" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0" Cursor="Hand" Click="OpenNotImpWin" Background="DarkGray"/>

                    <Grid Width="40" VerticalAlignment="Center">
                        <Button Content="🛒" FontSize="18" Foreground="White" HorizontalAlignment="Center" Click="OpenNotImpWin" Background="DarkGray"/>
                        <Border Background="#444444" CornerRadius="10" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0">
                            <TextBlock Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>