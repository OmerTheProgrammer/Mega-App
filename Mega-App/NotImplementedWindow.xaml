<Window x:Class="MegaApp.NotImplementedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MegaApp"
        mc:Ignorable="d"
        Title="Information" Height="200" Width="400" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize" 
        WindowStyle="ToolWindow">
    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Feature Not Implemented" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10" 
                       HorizontalAlignment="Center"/>

            <TextBlock Text="This part of the application is still under development." 
                       FontSize="12" 
                       Margin="0,0,0,20" 
                       TextAlignment="Center" 
                       TextWrapping="Wrap"/>

            <Button Content="OK" 
                    Width="75" 
                    Height="25" 
                    IsDefault="True" 
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>